# PostgreSQL connection string
# When using Docker Compose (same DB as the app), use:
DATABASE_URL=postgresql://inventario:inventario@localhost:5432/inventario
# Otherwise replace with your actual username, password, and database name
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/inventario

# Optional: Server port (default: 5000)
# PORT=5000
# Bind host (default is localhost for safer local deployments)
# Use BIND_HOST=0.0.0.0 only when you intentionally expose through Docker/proxy.
# BIND_HOST=127.0.0.1
# Trust reverse-proxy forwarded IP headers (set true only behind trusted proxy)
# TRUST_PROXY=false

# Backup (for npm run backup) — layout and restore: docs/BACKUP-RESTORE.md
# POSTGRES_CONTAINER=inventariolitea-postgres-1   (exact name from: docker ps --format "{{.Names}}")
# BACKUP_DIR=                   (optional; default is <repo>/backups, e.g. E:\...\Inventario Lite A\backups)
# BACKUP_RETENTION_DAYS=7
# BACKUP_COMPRESS=true         (compress to .7z or .tar.gz; set false to disable)
# BACKUP_SKIP_UPLOADS=true     (database only, ~few MB; images excluded - big space saver)
# BACKUP_7Z_PATH=              (path to 7z.exe for best compression; auto-detected on Windows)
# PG_DUMP_PATH=pg_dump         (only if PostgreSQL is installed locally, not in Docker)
# PG_RESTORE_PATH=pg_restore   (optional restore tool path for verify-restore job)
# BACKUP_VERIFY_SKIP_UPLOADS_CHECK=true  (optional: skip uploads presence check in verify job)
# INTEGRITY_REPORT_DIR=reports/integrity (optional; where integrity scan artifacts are written)
# INTEGRITY_SAMPLE_LIMIT=25    (optional; max sample rows included per check in report)

# Session secret (change in production!)
# SESSION_SECRET=your-random-secret-at-least-32-chars
